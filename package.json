{
  "name": "vscode-serial-monitor-pro",
  "displayName": "Serial Monitor Pro",
  "description": "Serial Monitor with timeline recording and audio commentary playback",
  "version": "0.1.0",
  "publisher": "millsit",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tenacioustechie/vscode-serial-monitor-pro"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "serial",
    "monitor",
    "serial port",
    "UART",
    "recording",
    "playback",
    "timeline"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "serialMonitorPro.openMonitor",
        "title": "Open Monitor",
        "category": "Serial Monitor Pro",
        "icon": "$(plug)"
      },
      {
        "command": "serialMonitorPro.refreshPorts",
        "title": "Refresh Ports",
        "category": "Serial Monitor Pro",
        "icon": "$(refresh)"
      },
      {
        "command": "serialMonitorPro.startRecording",
        "title": "Start Recording",
        "category": "Serial Monitor Pro",
        "icon": "$(circle-filled)"
      },
      {
        "command": "serialMonitorPro.stopRecording",
        "title": "Stop Recording",
        "category": "Serial Monitor Pro",
        "icon": "$(debug-stop)"
      },
      {
        "command": "serialMonitorPro.openPlayback",
        "title": "Open Session Playback",
        "category": "Serial Monitor Pro",
        "icon": "$(play)"
      },
      {
        "command": "serialMonitorPro.refreshSessions",
        "title": "Refresh Sessions",
        "category": "Serial Monitor Pro",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "serialMonitorPro",
          "title": "Serial Monitor Pro",
          "icon": "$(plug)"
        }
      ]
    },
    "views": {
      "serialMonitorPro": [
        {
          "id": "serialMonitorPorts",
          "name": "Serial Ports"
        },
        {
          "id": "serialMonitorSessions",
          "name": "Recorded Sessions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "serialMonitorPro.refreshPorts",
          "when": "view == serialMonitorPorts",
          "group": "navigation"
        },
        {
          "command": "serialMonitorPro.refreshSessions",
          "when": "view == serialMonitorSessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "serialMonitorPro.openMonitor",
          "when": "view == serialMonitorPorts",
          "group": "inline"
        },
        {
          "command": "serialMonitorPro.openPlayback",
          "when": "view == serialMonitorSessions",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Serial Monitor Pro",
      "properties": {
        "serialMonitorPro.defaultBaudRate": {
          "type": "number",
          "default": 115200,
          "description": "Default baud rate for serial connections"
        },
        "serialMonitorPro.customBaudRates": {
          "type": "array",
          "default": [],
          "items": {
            "type": "number"
          },
          "description": "Additional custom baud rates to show in the selector"
        },
        "serialMonitorPro.defaultLineEnding": {
          "type": "string",
          "default": "\\n",
          "enum": [
            "",
            "\\n",
            "\\r",
            "\\r\\n"
          ],
          "enumDescriptions": [
            "None",
            "LF (\\n)",
            "CR (\\r)",
            "CRLF (\\r\\n)"
          ],
          "description": "Default line ending appended to sent messages"
        },
        "serialMonitorPro.timestampEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Show timestamps on received serial data"
        },
        "serialMonitorPro.sessionStoragePath": {
          "type": "string",
          "default": "",
          "description": "Custom path for storing recording sessions. Leave empty to use workspace .serial-sessions/ directory."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "node-record-lpcm16": "^1.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0"
  }
}
